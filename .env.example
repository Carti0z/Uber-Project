# Database — PostgreSQL (Railway plugin or local Docker: docker compose up -d)
DATABASE_URL="postgresql://movee:movee@localhost:5432/movee"

# Auth — generate a long random string for production
JWT_SECRET="change-this-to-a-long-random-secret"

# Public URL of your live site (no trailing slash)
NEXT_PUBLIC_APP_NAME="Movee"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Fare settings
NEXT_PUBLIC_BASE_FARE=2.50
NEXT_PUBLIC_PER_KM_RATE=1.20
NEXT_PUBLIC_PER_MIN_RATE=0.25

# Commission (0.15 = 15%)
PLATFORM_COMMISSION_RATE=0.15
NEXT_PUBLIC_COMMISSION_RATE=0.15

# Server
NODE_ENV=production
PORT=3000
