# Database — use PostgreSQL in production (see README)
DATABASE_URL="file:./dev.db"

# Auth — generate a long random string for production
JWT_SECRET="change-this-to-a-long-random-secret"

# Public URL of your live site (no trailing slash)
NEXT_PUBLIC_APP_NAME="Movee"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Fare settings
NEXT_PUBLIC_BASE_FARE=2.50
NEXT_PUBLIC_PER_KM_RATE=1.20
NEXT_PUBLIC_PER_MIN_RATE=0.25

# Commission (0.15 = 15%)
PLATFORM_COMMISSION_RATE=0.15
NEXT_PUBLIC_COMMISSION_RATE=0.15

# Server
NODE_ENV=production
PORT=3000

# Prembly (driver document validation)
PREMBLY_API_KEY="live_sk_12ac1f7f046740549ec67c73a1e5f88a"
PREMBLY_APP_ID=""
PREMBLY_BASE_URL="https://api.prembly.com"
